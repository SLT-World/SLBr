<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net9.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <StartupObject>SLBr.Program</StartupObject>
    <ProduceReferenceAssembly>True</ProduceReferenceAssembly>
    <SignAssembly>False</SignAssembly>
    <ApplicationIcon>Resources\SLBr.ico</ApplicationIcon>
    <Copyright>Copyright (c) SLT Softwares. All rights reserved.</Copyright>
    <AssemblyVersion>2026.5.30.0</AssemblyVersion>
    <FileVersion>2026.5.30.0</FileVersion>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <Platforms>AnyCPU;x64</Platforms>
    <Company>$(Authors)</Company>
    <LangVersion>preview</LangVersion>
  </PropertyGroup>
	
  <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Debug|AnyCPU'">
    <DebugType>portable</DebugType>
  </PropertyGroup>

  <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Debug|x64'">
    <DebugType>portable</DebugType>
  </PropertyGroup>

	<PropertyGroup Condition="'$(Configuration)' == 'Debug'">
		<DebugType>portable</DebugType>
  </PropertyGroup>

	<PropertyGroup Condition="'$(Configuration)' == 'Release'">
		<GenerateDocumentationFile>false</GenerateDocumentationFile>
    <DebugType>none</DebugType>
	<DebugSymbols>false</DebugSymbols>
	<AllowedReferenceRelatedFileExtensions>*.pdb</AllowedReferenceRelatedFileExtensions>
	<ExcludeFilesFromDeployment>bin\**\*.pdb</ExcludeFilesFromDeployment>
  </PropertyGroup>

  <ItemGroup>
    <Compile Remove="Benchmark.cs" />
    <Compile Remove="Controls\ReportWindow.xaml.cs" />
  </ItemGroup>

  <ItemGroup>
    <Page Remove="Controls\ReportWindow.xaml" />
  </ItemGroup>

  <ItemGroup>
    <COMReference Include="SHDocVw">
      <WrapperTool>tlbimp</WrapperTool>
      <VersionMinor>1</VersionMinor>
      <VersionMajor>1</VersionMajor>
      <Guid>eab22ac0-30c1-11cf-a7eb-0000c05bae0b</Guid>
      <Lcid>0</Lcid>
      <Isolated>false</Isolated>
      <EmbedInteropTypes>true</EmbedInteropTypes>
    </COMReference>
  </ItemGroup>

  <ItemGroup>
    <Content Include="Resources\SLBr.ico">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
    </Content>
  </ItemGroup>

  <ItemGroup>
    <None Include="Benchmark.cs">
      <CopyToOutputDirectory>Never</CopyToOutputDirectory>
    </None>
    <None Include="Controls\ReportWindow.xaml" />
    <None Include="Controls\ReportWindow.xaml.cs" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="CefSharp.Wpf.HwndHost" Version="149.0.40" />
    <PackageReference Include="Microsoft.Web.WebView2" Version="1.0.4071-prerelease" />
    <PackageReference Include="NUglify" Version="1.21.17" PrivateAssets="all" />
  </ItemGroup>

  <ItemGroup>
    <Resource Include="Fonts\SLBr Icons.ttf" />
  </ItemGroup>

  <ItemGroup>
    <Compile Update="Pages\DownloadsPage.xaml.cs">
      <SubType>Code</SubType>
    </Compile>
    <Compile Update="Pages\HistoryPage.xaml.cs">
      <SubType>Code</SubType>
    </Compile>
    <Compile Update="Pages\FavouritesPage.xaml.cs">
      <SubType>Code</SubType>
    </Compile>
  </ItemGroup>

  <ItemGroup>
    <None Update="Resources\credits.html">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
    </None>
    <None Update="Resources\guest.html">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
    </None>
    <None Update="Resources\private.html">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
    </None>
    <None Update="Resources\newtab.html">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
    </None>
    <None Update="Resources\SLBr.ico">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
    <None Update="Resources\style.css">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
    </None>
    <None Update="Resources\tetris.html">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
    </None>
    <None Update="Resources\tetris.js">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
    </None>
  </ItemGroup>

  <ItemGroup>
    <PackageReference Update="chromiumembeddedframework.runtime.win-arm64" Version="149.0.4" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Update="chromiumembeddedframework.runtime.win-x64" Version="149.0.4" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Update="chromiumembeddedframework.runtime.win-x86" Version="149.0.4" />
  </ItemGroup>
	
	<Target Name="RemoveUnusedAssembly" BeforeTargets="ResolveAssemblyReferences">
		<ItemGroup>
			<Reference Remove="@(Reference->WithMetadataValue('FileName', 'Microsoft.Web.WebView2.WinForms'))"/>
		</ItemGroup>
	</Target>
	
	<Target Name="RemoveDuplicated" BeforeTargets="AssignTargetPaths">
		<ItemGroup>
			<Content Remove="@(Content)" Condition="%(Content.Link) == 'runtimes\win-x64\native\WebView2Loader.dll'" />
		</ItemGroup>
	</Target>

	<Target Name="FilterPublishItems" BeforeTargets="ComputeFilesToPublish">
		<ItemGroup>
			<ResolvedFileToPublish Remove="@(ResolvedFileToPublish)" Condition="%(Extension) == '.pdb'" />
			<ResolvedFileToPublish Remove="@(ResolvedFileToPublish)" Condition="%(Extension) == '.xml'" />
			<ResolvedFileToPublish Remove="@(ResolvedFileToPublish)" Condition="$([System.String]::new('%(RelativeDir)').Contains('locales')) And '%(Filename)' != 'en-US'" />
		</ItemGroup>
	</Target>
	
	<Target Name="PublishTask" AfterTargets="Publish">
		<Copy SourceFiles="..\Updater\bin\$(Configuration)\net\publish\Updater.exe" DestinationFolder="$(PublishDir)" />
		<Delete Files="$(PublishDir)\CefSharp.BrowserSubprocess.exe" />
		<Delete Files="$(PublishDir)\CefSharp.BrowserSubprocess.dll" />
		<Delete Files="$(PublishDir)\CefSharp.BrowserSubprocess.runtimeconfig.json" />
		<Exec Command="powershell -NoProfile -ExecutionPolicy Bypass -File &quot;$(MSBuildProjectDirectory)\minify.ps1&quot; -PublishDir &quot;$(PublishDir.TrimEnd('\'))&quot;" />
	</Target>

	<!--<Target Name="RemoveWinFormsDll" AfterTargets="Build">
		<Delete Files="$(OutputPath)\Microsoft.Web.WebView2.WinForms.dll"/>
		<Delete Files="$(OutputPath)\Microsoft.Web.WebView2.WinForms.xml"/>
	</Target>-->
</Project>
